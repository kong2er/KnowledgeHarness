# KnowledgeHarness API integration environment template
# 复制为 .env 后按需填入；未填时系统会自动降级，不会中断主流程。

# -------- Unified API (recommended) --------
# 中间处理阶段默认共用这一套 API 设置
KNOWLEDGEHARNESS_API_URL=
KNOWLEDGEHARNESS_API_KEY=
# 可选：接口风格 custom | openai_compatible | auto（默认 auto）
KNOWLEDGEHARNESS_API_STYLE=auto
# 可选：openai_compatible 风格下的默认模型
KNOWLEDGEHARNESS_API_MODEL=deepseek-chat

# -------- Optional per-module override --------
# 若留空则自动回退到 KNOWLEDGEHARNESS_API_URL / KNOWLEDGEHARNESS_API_KEY
TOPIC_CLASSIFIER_API_URL=
TOPIC_CLASSIFIER_API_KEY=
# 可选：module override（custom | openai_compatible | auto）
TOPIC_CLASSIFIER_API_STYLE=
# 可选：module override model（openai_compatible）
TOPIC_CLASSIFIER_API_MODEL=
# 主题粗分类模板文件路径（可选）
TOPIC_CLASSIFIER_API_TEMPLATE=config/api_payload_templates.json

# Web enrichment override（可选）
WEB_ENRICHMENT_API_URL=
WEB_ENRICHMENT_API_KEY=
# 可选：module override（custom | openai_compatible | auto）
WEB_ENRICHMENT_API_STYLE=
# 可选：module override model（openai_compatible）
WEB_ENRICHMENT_API_MODEL=
# Web enrichment 模板文件路径（可选）
WEB_ENRICHMENT_API_TEMPLATE=config/api_payload_templates.json

# 图片 OCR API 协助（可选，默认回退统一配置）
IMAGE_OCR_API_URL=
IMAGE_OCR_API_KEY=
IMAGE_OCR_API_STYLE=
IMAGE_OCR_API_MODEL=
IMAGE_OCR_API_TEMPLATE=config/api_payload_templates.json
# 可选：图片 OCR 请求最大字节数（默认 8MB）
IMAGE_OCR_MAX_BYTES=8388608
# 可选：图片 OCR 协助策略
# - fallback_only: 仅本地 OCR 失败/空文本时才调用 API
# - auto: 本地失败/空文本，或本地结果过短时调用 API 并择优
# - prefer_api: 只要启用 API 协助就优先使用 API 结果
IMAGE_OCR_ENHANCE_MODE=auto
# auto 模式下，本地 OCR 低于该质量分（默认 40）会触发 API 增强
IMAGE_OCR_ENHANCE_MIN_SCORE=40
# auto 模式下，API 结果需达到 max(local+delta, local*ratio) 才覆盖本地
IMAGE_OCR_ENHANCE_RATIO=1.1
IMAGE_OCR_ENHANCE_MIN_DELTA=6

# 内容分类（chunk 级）API 协助（可选，默认回退统一配置）
CONTENT_CLASSIFIER_API_URL=
CONTENT_CLASSIFIER_API_KEY=
CONTENT_CLASSIFIER_API_STYLE=
CONTENT_CLASSIFIER_API_MODEL=
CONTENT_CLASSIFIER_API_TEMPLATE=config/api_payload_templates.json

# 整理编排（stage summarize）API 协助（可选，默认回退统一配置）
NOTES_ORGANIZER_API_URL=
NOTES_ORGANIZER_API_KEY=
NOTES_ORGANIZER_API_STYLE=
NOTES_ORGANIZER_API_MODEL=
NOTES_ORGANIZER_API_TEMPLATE=config/api_payload_templates.json
