# KnowledgeHarness API integration environment template
# 复制为 .env 后按需填入；未填时系统会自动降级，不会中断主流程。

# -------- Unified API (recommended) --------
# 中间处理阶段默认共用这一套 API 设置
KNOWLEDGEHARNESS_API_URL=
KNOWLEDGEHARNESS_API_KEY=
# 可选：接口风格 custom | openai_compatible | auto（默认 auto）
KNOWLEDGEHARNESS_API_STYLE=auto
# 可选：openai_compatible 风格下的默认模型
KNOWLEDGEHARNESS_API_MODEL=deepseek-chat

# -------- Optional per-module override --------
# 若留空则自动回退到 KNOWLEDGEHARNESS_API_URL / KNOWLEDGEHARNESS_API_KEY
TOPIC_CLASSIFIER_API_URL=
TOPIC_CLASSIFIER_API_KEY=
# 可选：module override（custom | openai_compatible | auto）
TOPIC_CLASSIFIER_API_STYLE=
# 可选：module override model（openai_compatible）
TOPIC_CLASSIFIER_API_MODEL=
# 主题粗分类模板文件路径（可选）
TOPIC_CLASSIFIER_API_TEMPLATE=config/api_payload_templates.json

# Web enrichment override（可选）
WEB_ENRICHMENT_API_URL=
WEB_ENRICHMENT_API_KEY=
# 可选：module override（custom | openai_compatible | auto）
WEB_ENRICHMENT_API_STYLE=
# 可选：module override model（openai_compatible）
WEB_ENRICHMENT_API_MODEL=
# Web enrichment 模板文件路径（可选）
WEB_ENRICHMENT_API_TEMPLATE=config/api_payload_templates.json
